// ═══════════════════════════════════════════════════════════════
// SKEMA DATABASE — xales.id
// Multi-tenant: 1 baris Tenant = 1 user/toko. Semua data lain
// (Product, Order, Event) selalu terikat ke tenantId biar terisolasi.
// ═══════════════════════════════════════════════════════════════

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Tenant = 1 akun user/toko ──
model Tenant {
  id                 String   @id @default(cuid())
  name               String
  slug               String   @unique // dipakai di URL: xales.id/toko-nama
  email              String   @unique
  passwordHash       String

  // Kredensial pembayaran milik tenant sendiri (WAJIB dienkripsi saat disimpan production)
  midtransServerKey  String?
  midtransClientKey  String?
  midtransIsProd     Boolean  @default(false)

  // Kanal notifikasi
  telegramChatId     String?

  // Pilihan AI buat fitur "Buatkan dengan AI" — biar user bebas milih
  aiProvider         String   @default("anthropic") // anthropic | openai | none
  aiApiKey           String?  // kunci API milik user sendiri (kosong = pakai jatah gratis platform, khusus anthropic)
  aiTokensUsed       Int      @default(0)     // total token yang udah dipakai dari jatah gratis
  aiTokenLimit       Int      @default(25000) // jatah gratis awal

  createdAt          DateTime @default(now())
  products           Product[]
}

// ── Product = 1 produk yang dijual (ebook, jasa, dll) ──
model Product {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id])

  name          String
  slug          String   // dipakai di URL landing page: xales.id/toko-nama/nama-produk
  description   String?
  price         Int
  isPhysical    Boolean  @default(false) // true = butuh alamat + kirim manual

  // Untuk produk digital: link file (Drive/Supabase Storage) yang dikirim otomatis
  digitalFileUrl String?

  // ── Konten tambahan landing page (semua opsional) ──
  benefitPoints String?  // poin manfaat, 1 baris = 1 poin
  photoUrl      String?  // foto produk
  guaranteeText String?  // teks garansi
  faqJson       String?  // daftar tanya-jawab, disimpan JSON [{q,a}]

  // ── Scarcity — semua berbasis data asli, bukan settingan bohongan ──
  stockEnabled  Boolean  @default(false)
  stockQty      Int?     // stok awal, sisa dihitung dari jumlah pesanan lunas
  showSoldCount Boolean  @default(false) // tampilkan "sudah X terjual"
  showViewingNow Boolean @default(false) // tampilkan "X orang lagi lihat"
  promoPrice    Int?     // harga promo, dipakai kalau lebih kecil dari price & belum lewat batas waktu
  promoEndsAt   DateTime?

  // ── Social proof pop-up (nama pembeli asli, disingkat) ──
  socialProofEnabled Boolean @default(false)

  createdAt     DateTime @default(now())
  orders        Order[]
  events        Event[]

  @@unique([tenantId, slug])
}

// ── Order = 1 transaksi pembelian ──
model Order {
  id               String   @id @default(cuid())
  orderCode        String   @unique // dikirim ke Midtrans sebagai order_id

  productId        String
  product          Product  @relation(fields: [productId], references: [id])

  buyerName        String
  buyerEmail       String
  buyerPhone       String
  shippingAddress  String?  // wajib diisi kalau product.isPhysical = true

  paymentStatus    String   @default("pending") // pending | belum_bayar | paid | failed | refund
  shippingStatus   String?  // belum_dikirim | dikirim | selesai (khusus fisik)
  paymentType      String?  // qris, bank_transfer, dll dari Midtrans
  visitorId        String?  // buat nyambungin ke leads yang belum sempat checkout

  createdAt        DateTime @default(now())

  @@index([visitorId, productId])
}

// ── Event = 1 catatan funnel (page_view, cta_click, checkout_start, payment_success) ──
model Event {
  id         String   @id @default(cuid())

  productId  String
  product    Product  @relation(fields: [productId], references: [id])

  type       String   // page_view | cta_click | checkout_start | payment_success
  visitorId  String   // id anonim per pengunjung, biar bisa dihitung funnel per sesi

  createdAt  DateTime @default(now())

  @@index([productId, type])
}

# ═══════════════════════════════════════════════════════════════
# ENV VARIABLES — xales.id
# Copy file ini jadi .env lalu isi nilainya masing-masing.
# JANGAN commit file .env (isi rahasia) ke Git — hanya .env.example ini.
# ═══════════════════════════════════════════════════════════════

# Dari Railway > project kamu > klik service Postgres > tab "Connect" > Connection URL
DATABASE_URL="postgresql://user:password@host:5432/railway"

# Kunci buat sesi login (auth pakai JWT sendiri, gak pakai Supabase Auth lagi)
# generate sekali pakai: openssl rand -base64 32
AUTH_SECRET=""

# Kunci untuk enkripsi midtransServerKey tiap tenant sebelum disimpan ke DB
# generate sekali pakai: openssl rand -base64 32
CREDENTIAL_ENCRYPTION_KEY=""

# CATATAN: ANTHROPIC_API_KEY gak dipakai lagi di sini.
# Fitur "Buatkan dengan AI" sekarang pakai kunci API milik masing-masing user
# sendiri, diisi lewat halaman Pengaturan AI di dashboard.

# Dari @BotFather di Telegram (buat 1 bot khusus xales.id)
TELEGRAM_BOT_TOKEN=""

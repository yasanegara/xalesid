# ═══════════════════════════════════════════════════════════════
# ENV VARIABLES — xales.id
# Copy file ini jadi .env lalu isi nilainya masing-masing.
# JANGAN commit file .env (isi rahasia) ke Git — hanya .env.example ini.
# ═══════════════════════════════════════════════════════════════

# Dari Railway > project kamu > klik service Postgres > tab "Connect" > Connection URL
DATABASE_URL="postgresql://user:password@host:5432/railway"

# Kunci buat sesi login (auth pakai JWT sendiri, gak pakai Supabase Auth lagi)
# generate sekali pakai: openssl rand -base64 32
AUTH_SECRET=""

# Kunci untuk enkripsi midtransServerKey tiap tenant sebelum disimpan ke DB
# generate sekali pakai: openssl rand -base64 32
CREDENTIAL_ENCRYPTION_KEY=""

# Dari console.anthropic.com > API Keys — dipakai buat jatah gratis 25.000 token/toko
# (kalau user gak isi kunci Anthropic sendiri). Isi saldo di akun ini secukupnya.
ANTHROPIC_API_KEY=""

# CATATAN: fitur AI juga bisa pakai kunci API milik masing-masing user sendiri
# (Anthropic atau OpenAI), diisi lewat halaman Pengaturan AI di dashboard.
# Kalau user isi kunci sendiri, jatah gratis platform gak kepakai/gak berkurang.

# Dari @BotFather di Telegram — 1 bot buat semua toko, dipakai kirim notifikasi
TELEGRAM_BOT_TOKEN=""
# Username bot-nya (tanpa @), contoh: xales_notif_bot
TELEGRAM_BOT_USERNAME=""

# Dari @BotFather di Telegram (buat 1 bot khusus xales.id)
TELEGRAM_BOT_TOKEN=""
